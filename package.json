{
    "name": "aethon-arion-c1",
    "version": "0.4.5",
    "description": "The Arion C1 model and pipeline class implementations",
    "repository": "github:aethonholdings/aethon-arion-c1",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "watch": "tsc -w & nodemon -q -w dist dist/index.js",
        "document": "npx typedoc src/index.ts"
    },
    "author": "Konstantinos Dimitriou",
    "license": "MIT",
    "dependencies": {
        "aethon-arion-pipeline": "^0.5.4"
    },
    "peerDependencies": {
        "flat": "^5.0.2",
        "rxjs": "~7.8.1"
    },
    "devDependencies": {
        "@types/jasmine": "^5.1.4",
        "@types/jest": "^30.0.0",
        "@types/node": "^20.11.14",
        "@typescript-eslint/eslint-plugin": "^6.20.0",
        "@typescript-eslint/parser": "^6.20.0",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "9.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "jasmine": "^5.1.0",
        "jasmine-console-reporter": "^3.1.0",
        "jasmine-reporters": "^2.5.2",
        "jest": "^30.2.0",
        "prettier": "^3.2.4",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.5.2"
    }
}
